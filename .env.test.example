# Shared
NODE_ENV=production

# Public URLs
NEXT_PUBLIC_APP_URL=https://events-test.example.com
NEXT_PUBLIC_API_URL=https://api.events-test.example.com
API_INTERNAL_URL=http://api:4000

# Ports
WEB_PORT=3000
API_PORT=4000
MAILPIT_HTTP_PORT=8025

# Database / Queue
POSTGRES_DB=eventmanager
POSTGRES_USER=eventmanager
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql://eventmanager:replace-with-strong-password@postgres:5432/eventmanager
REDIS_URL=redis://redis:6379

# Auth / Tokens
JWT_SECRET=replace-with-long-random-secret
INVITE_TOKEN_SECRET=replace-with-second-long-random-secret

# Mail
MAIL_FROM=events-test@example.com
# Local Mailpit default. For real test mails, replace with an SMTP URL, e.g.
# smtp://USER:PASSWORD@smtp.example.com:587?secure=false
# smtps://USER:PASSWORD@smtp.example.com:465
# smtp://SMTP_RELAY_HOST:25?ignoreTLS=true
MAIL_TRANSPORT_URL=smtp://mailpit:1025
MAIL_TLS_REJECT_UNAUTHORIZED=true
MAIL_CONNECTION_TIMEOUT_MS=10000
MAIL_GREETING_TIMEOUT_MS=10000
MAIL_SOCKET_TIMEOUT_MS=20000

# Initial admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=replace-with-strong-password
SEED_ADMIN_FIRST_NAME=Test
SEED_ADMIN_LAST_NAME=Admin
