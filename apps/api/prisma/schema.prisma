generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EVENT_PLANNER
  STAFF
  CHECK_IN
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum InvitationStatus {
  DRAFT
  SCHEDULED
  SENT
  REGISTERED
  DECLINED
  CHECKED_IN
  NO_SHOW
  CANCELLED
}

enum RegistrationResponse {
  ACCEPTED
  DECLINED
}

enum CheckInMethod {
  MANUAL
  QR
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  passwordHash String  @map("password_hash")
  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  role        UserRole @default(STAFF)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  events      Event[]
  imports     ContactImport[]
  checkIns    CheckIn[]

  @@map("users")
}

model Contact {
  id          String   @id @default(cuid())
  salutation  String?
  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  email       String   @unique
  phone       String?
  company     String?
  jobTitle    String?  @map("job_title")
  street      String?
  postalCode  String?  @map("postal_code")
  city        String?
  country     String?
  tags        String[]
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  invitations EventInvitation[]

  @@map("contacts")
}

model ContactImport {
  id               String   @id @default(cuid())
  uploadedByUserId String   @map("uploaded_by_user_id")
  filename         String
  sourceType       String   @map("source_type")
  status           String
  totalRows        Int      @default(0) @map("total_rows")
  importedRows     Int      @default(0) @map("imported_rows")
  errorRows        Int      @default(0) @map("error_rows")
  mappingJson      Json?    @map("mapping_json")
  errorLogJson     Json?    @map("error_log_json")
  createdAt        DateTime @default(now()) @map("created_at")

  uploadedBy       User     @relation(fields: [uploadedByUserId], references: [id])

  @@map("contact_imports")
}

model Event {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  description     String?
  guestPageTitle  String?       @map("guest_page_title")
  guestPageIntro  String?       @map("guest_page_intro")
  guestPageInfo   String?       @map("guest_page_info")
  guestAcceptLabel String?      @map("guest_accept_label")
  guestDeclineLabel String?     @map("guest_decline_label")
  locationName    String        @map("location_name")
  locationAddress String?       @map("location_address")
  startsAt        DateTime      @map("starts_at")
  endsAt          DateTime      @map("ends_at")
  timezone        String
  capacity        Int?
  allowCompanion  Boolean       @default(false) @map("allow_companion")
  status          EventStatus   @default(DRAFT)
  createdByUserId String        @map("created_by_user_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  createdBy       User              @relation(fields: [createdByUserId], references: [id])
  invitations     EventInvitation[]
  emailJobs       EmailJob[]

  @@map("events")
}

model EventInvitation {
  id              String             @id @default(cuid())
  eventId         String             @map("event_id")
  contactId       String             @map("contact_id")
  status          InvitationStatus   @default(DRAFT)
  accessCode      String?            @unique @map("access_code")
  inviteTokenHash String             @map("invite_token_hash")
  checkinTokenHash String?           @map("checkin_token_hash")
  invitedAt       DateTime?          @map("invited_at")
  openedAt        DateTime?          @map("opened_at")
  respondedAt     DateTime?          @map("responded_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  event           Event              @relation(fields: [eventId], references: [id])
  contact         Contact            @relation(fields: [contactId], references: [id])
  registration    EventRegistration?
  checkIns        CheckIn[]
  emailJobs       EmailJob[]

  @@unique([eventId, contactId])
  @@map("event_invitations")
}

model EventRegistration {
  id                String               @id @default(cuid())
  eventInvitationId String               @unique @map("event_invitation_id")
  response          RegistrationResponse
  guestCount        Int                  @default(1) @map("guest_count")
  comment           String?
  dietaryRequirements String?            @map("dietary_requirements")
  companionRequested Boolean              @default(false) @map("companion_requested")
  companionFirstName String?              @map("companion_first_name")
  companionLastName  String?              @map("companion_last_name")
  registeredAt      DateTime             @default(now()) @map("registered_at")
  cancelledAt       DateTime?            @map("cancelled_at")

  invitation        EventInvitation      @relation(fields: [eventInvitationId], references: [id])

  @@map("event_registrations")
}

model CheckIn {
  id                String          @id @default(cuid())
  eventInvitationId String          @map("event_invitation_id")
  method            CheckInMethod
  checkedInAt       DateTime        @default(now()) @map("checked_in_at")
  checkedInByUserId String?         @map("checked_in_by_user_id")
  deviceInfo        String?         @map("device_info")
  companionPresent  Boolean         @default(false) @map("companion_present")

  invitation        EventInvitation @relation(fields: [eventInvitationId], references: [id])
  checkedInBy       User?           @relation(fields: [checkedInByUserId], references: [id])

  @@map("check_ins")
}

model EmailJob {
  id                String          @id @default(cuid())
  eventId           String?         @map("event_id")
  eventInvitationId String?         @map("event_invitation_id")
  templateType      String          @map("template_type")
  providerMessageId String?         @map("provider_message_id")
  status            String
  sentAt            DateTime?       @map("sent_at")
  errorMessage      String?         @map("error_message")

  event             Event?          @relation(fields: [eventId], references: [id])
  invitation        EventInvitation? @relation(fields: [eventInvitationId], references: [id])

  @@map("email_jobs")
}
